# Grocery Tracking System - Environment Configuration
# INSTRUCCIONES:
# 1. Copia este archivo a .env (en el directorio raíz del proyecto)
# 2. Reemplaza los valores con tus configuraciones
# 3. NUNCA commits el archivo .env a Git (ya está en .gitignore)
# 4. Los valores por defecto están optimizados para desarrollo local

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL SISTEMA
# ─────────────────────────────────────────────────────────────

# Directorio de datos locales (relativo a raíz del proyecto)
DATA_DIR=./data

# Archivo de historial de compras
HISTORY_FILE=./data/grocery_history.json

# Ambiente de ejecución: 'development' o 'production'
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE OCR (Reconocimiento de Texto en Tickets)
# ─────────────────────────────────────────────────────────────

# Habilitar procesamiento OCR
OCR_ENABLED=true

# Método OCR: 'cloud-vision' (Google Vision API), 'tesseract' (local)
OCR_METHOD=cloud-vision

# Idioma para OCR: 'es' (español), 'en' (inglés), 'pt' (portugués)
OCR_LANGUAGE=es

# Tamaño máximo de archivo de imagen (MB)
OCR_MAX_FILE_SIZE_MB=5

# Optimización de OCR: 'minimize-tokens' o 'best-accuracy'
OCR_OPTIMIZATION=minimize-tokens

# (Opcional) Clave API de Google Cloud Vision (requerida si OCR_METHOD=cloud-vision)
# Obtén una en: https://console.cloud.google.com/
GOOGLE_CLOUD_API_KEY=

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE ANÁLISIS
# ─────────────────────────────────────────────────────────────

# Habilitar análisis de patrones y estimaciones
ANALYSIS_ENABLED=true

# Mínimo de compras para detectar un patrón
MIN_PURCHASES_FOR_PATTERN=2

# Mínimo de compras para hacer una estimación
MIN_PURCHASES_FOR_ESTIMATION=3

# Umbral de frecuencia para patrones (0-100%)
FREQUENCY_THRESHOLD_PERCENT=80

# Tamaño promedio de la familia (usado en estimaciones)
FAMILY_SIZE=4

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE INTEGRACIÓN CARREFOUR
# ─────────────────────────────────────────────────────────────

# Habilitar integración con Carrefour Argentina
CARREFOUR_ENABLED=true

# Email de cuenta Carrefour (requerido si CARREFOUR_ENABLED=true)
CARREFOUR_EMAIL=

# Contraseña de cuenta Carrefour (requerido si CARREFOUR_ENABLED=true)
CARREFOUR_PASSWORD=

# Tipo de API: 'web-scraping' (automatizado) o 'api' (OAuth)
CARREFOUR_API_TYPE=web-scraping

# Sincronización automática con historial Carrefour
CARREFOUR_AUTO_SYNC=false

# Timeout para operaciones Carrefour (ms)
CARREFOUR_TIMEOUT=30000

# URL base de Carrefour Argentina
CARREFOUR_BASE_URL=https://www.carrefour.com.ar

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE ALMACENAMIENTO
# ─────────────────────────────────────────────────────────────

# Formato de almacenamiento: 'json' (local)
STORAGE_FORMAT=json

# Habilitar backups automáticos
BACKUP_ENABLED=false

# Directorio de backups (relativo a DATA_DIR)
BACKUP_DIR=./backups

# ─────────────────────────────────────────────────────────────
# CARACTERÍSTICAS OPCIONALES
# ─────────────────────────────────────────────────────────────

# Aprendizaje de patrones de compra
FEATURE_PATTERN_LEARNING=true

# Detección de tendencias estacionales
FEATURE_SEASONAL_DETECTION=true

# Seguimiento de precios
FEATURE_PRICE_TRACKING=true

# Estimación de cantidades
FEATURE_QUANTITY_ESTIMATION=true

# Sugerencias de compras
FEATURE_SHOPPING_SUGGESTIONS=true

# ─────────────────────────────────────────────────────────────
# LOGGING Y DEPURACIÓN
# ─────────────────────────────────────────────────────────────

# Nivel de logging: 'error', 'warn', 'info', 'debug', 'trace'
LOG_LEVEL=info

# Habilitar logs detallados de análisis
DEBUG_ANALYSIS=false

# Habilitar logs detallados de OCR
DEBUG_OCR=false

# ─────────────────────────────────────────────────────────────
# NOTAS IMPORTANTES
# ─────────────────────────────────────────────────────────────
# - Este archivo es un template. Copia y personaliza según necesites.
# - El archivo .env real NO debe estar en Git (protegido por .gitignore).
# - Para obtener las credenciales de Carrefour:
#   1. Crea una cuenta en carrefour.com.ar
#   2. Ingresa con tus credenciales (email y contraseña)
#   3. El sistema usará web-scraping para sincronizar automáticamente
# - Para usar Google Cloud Vision:
#   1. Crea un proyecto en Google Cloud Console
#   2. Habilita la API de Vision
#   3. Genera una clave API de servicio
#   4. Descarga el JSON y configura GOOGLE_CLOUD_API_KEY
