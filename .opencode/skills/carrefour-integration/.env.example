# Carrefour Integration - Credenciales Seguras
# INSTRUCCIONES: 
# 1. Copia este archivo a .env (en el mismo directorio)
# 2. Reemplaza los valores con tus datos de Carrefour Argentina
# 3. NUNCA commits el archivo .env a Git
# 4. Asegúrate que .env está en .gitignore

# Email de tu cuenta Carrefour
CARREFOUR_EMAIL=tu_email@ejemplo.com

# Contraseña de tu cuenta Carrefour
CARREFOUR_PASSWORD=tu_contraseña_segura

# (Opcional) Token de API si Carrefour lo proporciona
CARREFOUR_API_TOKEN=

# URL base de Carrefour Argentina
CARREFOUR_BASE_URL=https://www.carrefour.com.ar

# Modo de autenticación: 'web' (navegador automatizado) o 'api' (OAuth)
CARREFOUR_AUTH_MODE=web

# Timeout para operaciones de web scraping (ms)
CARREFOUR_TIMEOUT=30000
